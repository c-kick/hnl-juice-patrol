{
  "entity": {
    "sensor": {
      "discharge_rate": {
        "default": "mdi:battery-minus"
      },
      "predicted_empty": {
        "default": "mdi:battery-clock"
      },
      "days_remaining": {
        "default": "mdi:calendar-clock"
      },
      "soh": {
        "default": "mdi:heart-pulse"
      },
      "soh_cycling": {
        "default": "mdi:battery-heart"
      },
      "knee_risk": {
        "default": "mdi:chart-bell-curve"
      },
      "lowest_battery": {
        "default": "mdi:battery-alert"
      }
    },
    "binary_sensor": {
      "battery_low": {
        "default": "mdi:battery-check",
        "state": {
          "on": "mdi:battery-alert"
        }
      },
      "stale": {
        "default": "mdi:check-circle",
        "state": {
          "on": "mdi:clock-alert"
        }
      },
      "attention_needed": {
        "default": "mdi:battery-check-outline",
        "state": {
          "on": "mdi:battery-alert-variant"
        }
      }
    }
  },
  "services": {
    "force_refresh": {
      "service": "mdi:refresh"
    },
    "mark_replaced": {
      "service": "mdi:battery-sync"
    },
    "set_device_threshold": {
      "service": "mdi:battery-alert"
    },
    "ignore_device": {
      "service": "mdi:eye-off"
    },
    "unignore_device": {
      "service": "mdi:eye"
    }
  }
}
